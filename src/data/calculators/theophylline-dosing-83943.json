  "outputs": [
    {
      "type": "numeric",
      "id": "dosing_weight",
      "label": "Dosing Weight",
      "formula": "IF(sex == 1, IF(actual_total_weight >= 0.7 * (50 + 2.3 * (height - 60)) AND actual_total_weight <= 1.3 * (50 + 2.3 * (height - 60)), actual_total_weight, 50 + 2.3 * (height - 60) + 0.4 * (actual_total_weight - (50 + 2.3 * (height - 60)))), IF(actual_total_weight >= 0.7 * (45.5 + 2.3 * (height - 60)) AND actual_total_weight <= 1.3 * (45.5 + 2.3 * (height - 60)), actual_total_weight, 45.5 + 2.3 * (height - 60) + 0.4 * (actual_total_weight - (45.5 + 2.3 * (height - 60)))))",
      "precision": 2,
      "defaultUnit": "kg"
    },
    {
      "type": "numeric",
      "id": "volume_of_distribution",
      "label": "Volume of Distribution",
      "formula": "IF(obese == 1, IF(sex == 1, 0.5 * (50 + 2.3 * (height - 60)), 0.5 * (45.5 + 2.3 * (height - 60))), IF(patient_type == 1, IF(sex == 1, 0.7 * (50 + 2.3 * (height - 60)), 0.7 * (45.5 + 2.3 * (height - 60))), IF(patient_type == 1, 0.5 * dosing_weight, 0.7 * dosing_weight)))",
      "precision": 2,
      "defaultUnit": "L"
    },
    {
      "type": "numeric",
      "id": "clearance_of_salt_cls",
      "label": "Clearance of Salt (Cls)",
      "formula": "0.04 * (acute_pulmonary_edema + acute_viral_illness + chf + cimetidine + ciprofloxacin + cystic_fibrosis + erythromycin + hepatic_cirrhosis + influenza_vaccine + marijuana + phenobarbital_rifampin_inducers + phenytoin + smoker)",
      "precision": 2,
      "defaultUnit": "L/kg/hr"
    },
    {
      "type": "numeric",
      "id": "iv_loading_dose",
      "label": "IV Loading Dose",
      "formula": "target_steady_state_concentration_css * volume_of_distribution / salt_factors_s",
      "precision": 2,
      "defaultUnit": "mg"
    },
    {
      "type": "numeric",
      "id": "iv_continuous_infusion_dose",
      "label": "IV Continuous Infusion Dose",
      "formula": "target_steady_state_concentration_css * clearance_of_salt_cls / salt_factors_s",
      "precision": 2,
      "defaultUnit": "mg"
    },
    {
      "type": "numeric",
      "id": "oral_dose",
      "label": "Oral Dose",
      "formula": "target_steady_state_concentration_css * clearance_of_salt_cls * 8 / (f * salt_factors_s)",
      "precision": 2,
      "defaultUnit": "mg"
    },
    {
      "type": "numeric",
      "id": "iv_to_oral_dose_conversion",
      "label": "IV to Oral Dose Conversion",
      "formula": "salt_factors_s * iv_continuous_infusion_dose * 24",
      "precision": 2,
      "defaultUnit": "mg"
    }
  ],
