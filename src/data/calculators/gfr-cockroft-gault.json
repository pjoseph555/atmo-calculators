{
  "id": "gfr-cockroft-gault",
  "name": "GFR (Cockroft-Gault)",
  "status": "active",
  "complexity": "moderate",
  "inputs": [
    {
      "type": "numeric",
      "id": "age",
      "label": "Age"
    },
    {
      "type": "numeric",
      "id": "weight",
      "label": "Weight"
    },
    {
      "type": "numeric",
      "id": "serum_creatinine",
      "label": "Serum Creatinine"
    },
    {
      "type": "dropdown",
      "id": "gender",
      "label": "Gender",
      "options": [
        {
          "label": "Male",
          "value": 1
        },
        {
          "label": "Female",
          "value": 2
        }
      ]
    }
  ],
  "outputs": [
    {
      "type": "numeric",
      "id": "clearance",
      "label": "Clearance",
      "formula": "IF(gender == 1, 1.23 * weight * (140 - age) / serum_creatinine, 1.03 * weight * (140 - age) / serum_creatinine)",
      "precision": 2,
      "defaultUnit": "mL/min"
    }
  ],
  "version": 1,
  "createdAt": "2026-03-06T14:19:02.227Z",
  "updatedAt": "2026-03-06T14:19:02.227Z"
}