{
  "id": "iron-deficit",
  "name": "Iron Deficit",
  "status": "active",
  "complexity": "moderate",
  "inputs": [
    {
      "type": "numeric",
      "id": "weight",
      "label": "Weight"
    },
    {
      "type": "numeric",
      "id": "target_hb",
      "label": "Target Hb"
    },
    {
      "type": "numeric",
      "id": "actual_hb",
      "label": "Actual Hb"
    }
  ],
  "outputs": [
    {
      "type": "numeric",
      "id": "iron_deficit",
      "label": "Iron Deficit",
      "formula": "IF(weight > 33.33, weight * (target_hb - actual_hb) * 0.24 + 500, weight * (target_hb - actual_hb) * 0.24 + 15 * weight)",
      "precision": 2,
      "defaultUnit": "mg"
    }
  ],
