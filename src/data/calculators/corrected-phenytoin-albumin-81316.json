{
  "id": "corrected-phenytoin-albumin-81316",
  "name": "Corrected Phenytoin (Albumin)",
  "status": "active",
  "complexity": "moderate",
  "inputs": [
    {
      "type": "dropdown",
      "id": "patient_s_calculated_creatinine_clearanc",
      "label": "Patient's calculated Creatinine Clearance < 20?",
      "options": [
        {
          "label": "No",
          "value": 0
        },
        {
          "label": "Yes",
          "value": 1
        }
      ]
    },
    {
      "type": "numeric",
      "id": "phenytoin_level",
      "label": "Phenytoin Level"
    },
    {
      "type": "numeric",
      "id": "albumin",
      "label": "Albumin"
    }
  ],
  "outputs": [
    {
      "type": "numeric",
      "id": "corrected_level",
      "label": "Corrected level",
      "formula": "IF(patient_s_calculated_creatinine_clearanc == 1, phenytoin_level / (0.1 * albumin + 0.1), phenytoin_level / (0.2 * albumin + 0.1))",
      "precision": 2,
      "defaultUnit": "mg/L"
    }
  ],
  "version": 1,
  "createdAt": "2026-03-06T13:17:08.189Z",
  "updatedAt": "2026-03-06T13:17:08.189Z"
