{
  "id": "gfr-for-adults-mdrd",
  "name": "GFR for Adults (MDRD)",
  "status": "active",
  "complexity": "moderate",
  "inputs": [
    {
      "type": "numeric",
      "id": "age",
      "label": "Age"
    },
    {
      "type": "numeric",
      "id": "serum_creatinine",
      "label": "Serum Creatinine"
    },
    {
      "type": "numeric",
      "id": "serum_bun",
      "label": "Serum BUN"
    },
    {
      "type": "numeric",
      "id": "serum_albumin",
      "label": "Serum Albumin"
    },
    {
      "type": "dropdown",
      "id": "sex",
      "label": "Sex",
      "options": [
        {
          "label": "male",
          "value": 1
        },
        {
          "label": "female",
          "value": 0.762
        }
      ]
    },
    {
      "type": "dropdown",
      "id": "black",
      "label": "Black?",
      "options": [
        {
          "label": "Yes",
          "value": 1.18
        },
        {
          "label": "No",
          "value": 1
        }
      ]
    }
  ],
  "outputs": [
    {
      "type": "numeric",
      "id": "egfr",
      "label": "eGFR",
      "formula": "170 * serum_creatinine ^ -0.999 * age ^ -0.176 * serum_bun ^ -0.17 * serum_albumin ^ 0.318 * sex * black",
      "precision": 2,
      "defaultUnit": "mL/min"
    }
  ],
  "version": 1,
  "createdAt": "2026-03-06T14:19:01.944Z",
  "updatedAt": "2026-03-06T14:19:01.944Z"
}