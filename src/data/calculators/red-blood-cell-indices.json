{
  "id": "red-blood-cell-indices",
  "name": "Red Blood Cell Indices",
  "status": "active",
  "complexity": "moderate",
  "inputs": [
    {
      "type": "numeric",
      "id": "hemoglobin",
      "label": "Hemoglobin"
    },
    {
      "type": "numeric",
      "id": "hematocrit",
      "label": "Hematocrit"
    },
    {
      "type": "numeric",
      "id": "red_cell_count",
      "label": "Red cell count"
    }
  ],
  "outputs": [
    {
      "type": "numeric",
      "id": "mcv",
      "label": "MCV",
      "formula": "1000 * hematocrit * 0.01 / red_cell_count",
      "precision": 2,
      "defaultUnit": "fL"
    },
    {
      "type": "numeric",
      "id": "mch",
      "label": "MCH",
      "formula": "10 * hemoglobin / red_cell_count",
      "precision": 2,
      "defaultUnit": "pg"
    }
  ],
  "version": 1,
  "createdAt": "2026-03-06T13:16:04.397Z",
  "updatedAt": "2026-03-06T13:16:04.397Z"
}