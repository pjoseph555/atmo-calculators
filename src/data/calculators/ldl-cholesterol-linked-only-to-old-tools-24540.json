      "id": "triglycerides",
      "label": "Triglycerides"
    }
  ],
  "outputs": [
    {
      "type": "numeric",
      "id": "ldl_cholesterol",
      "label": "LDL Cholesterol",
      "formula": "total_cholesterol - hdl_cholesterol - triglycerides / 5",
      "precision": 2,
      "defaultUnit": "mg/dL"
    }
  ],
