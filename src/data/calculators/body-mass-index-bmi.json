{
  "id": "body-mass-index-bmi",
  "name": "Body Mass Index (BMI)",
  "status": "active",
  "complexity": "simple",
  "inputs": [
    {
      "type": "numeric",
      "id": "weight",
      "label": "Weight",
      "defaultUnit": "kg",
      "units": [
        {
          "label": "kg",
          "factor": 1
        },
        {
          "label": "lb",
          "factor": 0.454
        }
      ]
    },
    {
      "type": "numeric",
      "id": "height",
      "label": "Height",
      "defaultUnit": "m",
      "units": [
        {
          "label": "m",
          "factor": 1
        },
        {
          "label": "cm",
          "factor": 0.01
        },
        {
          "label": "ft",
          "factor": 0.304
        },
        {
          "label": "in",
          "factor": 0.0254
        }
      ]
    }
  ],
  "outputs": [
    {
      "type": "numeric",
      "id": "bmi",
      "label": "BMI",
      "formula": "weight / (height * height)",
      "precision": 2,
      "defaultUnit": "kg/m2"
    }
  ],
  "report": {
    "formula": "IF(bmi < 18.5, 0, IF(bmi < 25, 1, IF(bmi < 30, 2, 3)))",
    "variants": [
      {
        "id": "0",
        "template": "BMI: {bmi}<br />You are considered underweight."
      },
      {
        "id": "1",
        "template": "BMI: {bmi}<br />You are considered normal."
      },
      {
        "id": "2",
        "template": "BMI: {bmi}<br />You are considered overweight."
      },
      {
        "id": "3",
        "template": "BMI: {bmi}<br />You are considered obese."
      }
    ]
  },
  "version": 1,
  "createdAt": "2026-03-06T13:16:04.057Z",
  "updatedAt": "2026-03-06T13:16:04.057Z"
}
