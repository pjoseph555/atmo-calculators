{
  "id": "delta-gap-and-ratio-81325",
  "name": "Delta Gap and Ratio",
  "status": "active",
  "complexity": "moderate",
  "inputs": [
    {
      "type": "numeric",
      "id": "na",
      "label": "Na"
    },
    {
      "type": "numeric",
      "id": "cl",
      "label": "Cl"
    },
    {
      "type": "numeric",
      "id": "f3",
      "label": "f3"
    },
    {
      "type": "numeric",
      "id": "albumin",
      "label": "Albumin"
    },
    {
      "type": "numeric",
      "id": "normal_gap",
      "label": "Normal Gap"
    }
  ],
  "outputs": [
    {
      "type": "numeric",
      "id": "delta_gap",
      "label": "Delta Gap",
      "formula": "na - (cl + f3) - normal_gap + 0.25 * (40 - albumin) - (25 - f3)",
      "precision": 2,
      "defaultUnit": "mmol/L"
    },
    {
      "type": "numeric",
      "id": "delta_ratio",
      "label": "Delta Ratio",
      "formula": "(na - (cl + f3) - normal_gap + 0.25 * (40 - albumin)) / (25 - f3)",
      "precision": 2
    },
    {
      "type": "numeric",
      "id": "o3",
      "label": "o3",
      "formula": "25 - f3",
      "precision": 2,
      "defaultUnit": "mmol/L"
    },
    {
      "type": "numeric",
      "id": "delta_anion_gap",
      "label": "Delta Anion Gap",
      "formula": "na - (cl + f3) - normal_gap + 0.25 * (40 - albumin)",
      "precision": 2,
      "defaultUnit": "mmol/L"
    }
  ],
  "version": 1,
  "createdAt": "2026-03-06T13:17:08.230Z",
  "updatedAt": "2026-03-06T13:17:08.230Z"
