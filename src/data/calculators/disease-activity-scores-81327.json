{
  "id": "disease-activity-scores-81327",
  "name": "Disease Activity Scores",
  "status": "active",
  "complexity": "complex",
  "inputs": [
    {
      "type": "numeric",
      "id": "tender_joint_count",
      "label": "Tender Joint Count"
    },
    {
      "type": "numeric",
      "id": "swollen_joint_count",
      "label": "Swollen Joint Count"
    },
    {
      "type": "numeric",
      "id": "erythrocyte_sedimentation_rate",
      "label": "Erythrocyte Sedimentation Rate"
    },
    {
      "type": "numeric",
      "id": "subject_assessment",
      "label": "Subject Assessment"
    },
    {
      "type": "numeric",
      "id": "initial_das",
      "label": "Initial DAS"
    }
  ],
  "outputs": [
    {
      "type": "numeric",
      "id": "current_das",
      "label": "Current DAS",
      "formula": "0.56 * sqrt(tender_joint_count) + 0.28 * sqrt(swollen_joint_count) + 0.70 * ln(erythrocyte_sedimentation_rate) + 0.014 * subject_assessment",
      "precision": 2,
      "defaultUnit": "units"
    },
    {
      "type": "numeric",
      "id": "disease_activity",
      "label": "Disease Activity",
      "formula": "IF(current_das <= 3.2 AND current_das - initial_das > 1.2, 1, IF(current_das <= 3.2 AND current_das - initial_das > 0.6 AND current_das - initial_das <= 1.2, 2, IF(current_das <= 3.2 AND current_das - initial_das <= 0.6, 3, IF(current_das > 3.2 AND current_das <= 5.1 AND current_das - initial_das > 0.6, 2, IF(current_das > 3.2 AND current_das <= 5.1 AND current_das - initial_das <= 0.6, 3, IF(current_das > 5.1 AND current_das - initial_das > 1.2, 2, 3))))))",
      "precision": 2,
      "defaultUnit": "units"
    }
  ],
  "version": 1,
  "createdAt": "2026-03-06T13:17:08.240Z",
  "updatedAt": "2026-03-06T13:17:08.240Z"
}