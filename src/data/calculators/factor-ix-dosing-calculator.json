  ],
  "outputs": [
    {
      "type": "numeric",
      "id": "dosage_required",
      "label": "Dosage Required",
      "formula": "weight * desired_factor_ix_increase * 1",
      "precision": 2,
      "defaultUnit": "IU"
    }
  ],
