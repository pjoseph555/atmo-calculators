  "outputs": [
    {
      "type": "numeric",
      "id": "mean_arterial_pressure",
      "label": "Mean Arterial Pressure",
      "formula": "diastolic_bp + (systolic_bp - diastolic_bp) / 3",
      "precision": 2,
      "defaultUnit": "mmHg"
    }
