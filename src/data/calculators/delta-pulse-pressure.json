{
  "id": "delta-pulse-pressure",
  "name": "Delta Pulse Pressure",
  "status": "active",
  "complexity": "moderate",
  "inputs": [
    {
      "type": "numeric",
      "id": "maximum_systolic_bp",
      "label": "Maximum Systolic BP"
    },
    {
      "type": "numeric",
      "id": "minimum_systolic_bp",
      "label": "Minimum Systolic BP"
    },
    {
      "type": "numeric",
      "id": "maximum_diastolic_bp",
      "label": "Maximum Diastolic BP"
    },
    {
      "type": "numeric",
      "id": "minimum_diatolic_bp",
      "label": "Minimum Diatolic BP"
    }
  ],
  "outputs": [
    {
      "type": "numeric",
      "id": "delta_pp",
      "label": "Delta PP",
      "formula": "(maximum_systolic_bp - maximum_diastolic_bp - (minimum_systolic_bp - minimum_diatolic_bp)) / ((maximum_systolic_bp - maximum_diastolic_bp + (minimum_systolic_bp - minimum_diatolic_bp)) / 2) * 100",
      "precision": 2,
      "defaultUnit": "%"
    }
  ],
  "version": 1,
  "createdAt": "2026-03-06T14:19:02.175Z",
  "updatedAt": "2026-03-06T14:19:02.175Z"
}