{
  "id": "water-deficit",
  "name": "Water Deficit",
  "status": "active",
  "complexity": "moderate",
  "inputs": [
    {
      "type": "numeric",
      "id": "weight",
      "label": "Weight"
    },
    {
      "type": "numeric",
      "id": "measured_na",
      "label": "Measured Na"
    },
    {
      "type": "numeric",
      "id": "target_na",
      "label": "Target Na"
    },
    {
      "type": "dropdown",
      "id": "gender",
      "label": "Gender",
      "options": [
        {
          "label": "Male",
          "value": 1
        },
        {
          "label": "Female",
          "value": 2
        }
      ]
    }
  ],
  "outputs": [
    {
      "type": "numeric",
      "id": "water_deficit",
      "label": "Water deficit",
      "formula": "IF(gender == 1, 0.5 * weight * (measured_na / target_na - 1), 0.4 * weight * (measured_na / target_na - 1))",
      "precision": 2
    }
  ],
  "version": 1,
  "createdAt": "2026-03-06T14:19:02.441Z",
  "updatedAt": "2026-03-06T14:19:02.441Z"
}