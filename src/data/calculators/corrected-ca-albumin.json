{
  "id": "corrected-ca-albumin",
  "name": "Corrected Ca (Albumin)",
  "status": "active",
  "complexity": "simple",
  "inputs": [
    {
      "type": "numeric",
      "id": "serum_ca",
      "label": "Serum Ca"
    },
    {
      "type": "numeric",
      "id": "patient_albumin",
      "label": "Patient albumin"
    }
  ],
  "outputs": [
    {
      "type": "numeric",
      "id": "corrected_ca",
      "label": "Corrected Ca",
      "formula": "serum_ca + 0.8 * (4.0 - patient_albumin)",
      "precision": 2,
      "defaultUnit": "mg/dL"
    }
  ],
  "version": 1,
  "createdAt": "2026-03-06T14:19:02.131Z",
  "updatedAt": "2026-03-06T14:19:02.131Z"
}