{
  "id": "osmolal-gap-serum",
  "name": "Osmolal Gap (Serum)",
  "status": "active",
  "complexity": "moderate",
  "inputs": [
    {
      "type": "numeric",
      "id": "na",
      "label": "Na"
    },
    {
      "type": "numeric",
      "id": "urea",
      "label": "Urea"
    },
    {
      "type": "numeric",
      "id": "glucose",
      "label": "Glucose"
    },
    {
      "type": "numeric",
      "id": "ethanol",
      "label": "Ethanol"
    },
    {
      "type": "numeric",
      "id": "measured_osmolality",
      "label": "Measured Osmolality"
    }
  ],
  "outputs": [
    {
      "type": "numeric",
      "id": "calc_osmolality",
      "label": "Calc. Osmolality",
      "formula": "2 * na + urea + glucose + ethanol",
      "precision": 2,
      "defaultUnit": "mosm/kg"
    },
    {
      "type": "numeric",
      "id": "osmolal_gap",
      "label": "Osmolal Gap",
      "formula": "measured_osmolality - calc_osmolality",
      "precision": 2,
      "defaultUnit": "mosm/kg"
    }
  ],
  "version": 1,
  "createdAt": "2026-03-06T14:19:02.318Z",
  "updatedAt": "2026-03-06T14:19:02.318Z"
}