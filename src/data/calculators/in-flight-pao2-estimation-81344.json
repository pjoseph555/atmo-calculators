{
  "id": "in-flight-pao2-estimation-81344",
  "name": "In-Flight PaO2 Estimation",
  "status": "active",
  "complexity": "simple",
  "inputs": [
    {
      "type": "numeric",
      "id": "f1",
      "label": "f1"
    },
    {
      "type": "numeric",
      "id": "paco2",
      "label": "PaCO2"
    },
    {
      "type": "numeric",
      "id": "altitude",
      "label": "Altitude",
      "defaultUnit": "m",
      "units": [
        {
          "label": "m",
          "factor": 1
        },
        {
          "label": "ft",
          "factor": 0.3048
        }
      ]
    }
  ],
  "outputs": [
    {
      "type": "numeric",
      "id": "o1",
      "label": "o1",
      "formula": "1.59 + 0.98 * f1 + 0.0031 * altitude * 3.28 - 0.000061 * f1 * altitude * 3.28 - 0.000065 * paco2 * altitude * 3.28 + 0.000000092 * (altitude * 3.28) ^ 2",
      "precision": 2
    }
  ],
  "version": 1,
  "createdAt": "2026-03-06T13:17:08.316Z",
  "updatedAt": "2026-03-06T13:17:08.316Z"
}