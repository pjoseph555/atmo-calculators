{
  "id": "nac-dosage-regimen",
  "name": "NAC Dosage Regimen",
  "status": "active",
  "complexity": "simple",
  "inputs": [
    {
      "type": "numeric",
      "id": "patient_s_weight",
      "label": "Patient's Weight"
    }
  ],
  "outputs": [
    {
      "type": "numeric",
      "id": "first_dose",
      "label": "First Dose",
      "formula": "150 * patient_s_weight",
      "precision": 2,
      "defaultUnit": "mg"
    },
    {
      "type": "numeric",
      "id": "next_4_hours",
      "label": "Next 4 hours",
      "formula": "50 * patient_s_weight",
      "precision": 2,
      "defaultUnit": "mg"
    },
    {
      "type": "numeric",
      "id": "next_16_hours",
      "label": "Next 16 hours",
      "formula": "100 * patient_s_weight",
      "precision": 2,
      "defaultUnit": "mg"
    }
  ],
  "version": 1,
  "createdAt": "2026-03-06T14:19:02.313Z",
  "updatedAt": "2026-03-06T14:19:02.313Z"
}